generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                      String         @id @default(auto()) @map("_id") @db.ObjectId
  email                   String         @unique
  name                    String?
  handle                  String?        @unique
  image                   String?
  googleId                String?        @unique
  stripeCustomerId        String?
  subscriptionStatus      String?
  subscriptionOfferId     String?
  trialEndsAt             DateTime?
  currentPeriodEnd        DateTime?
  stripeSubscriptionId    String?
  referredByReferralId    String?        @db.ObjectId
  notificationPreferences Json?
  posts                   PlatformPost[] @relation("UserPosts")
  createdAt               DateTime       @default(now())

  subscription       UserSubscription? @relation("UserSubscriber")
  stories            Story[]           @relation("UserStories")
  comments           Comment[]
  referral           Referral?         @relation("UserOwnReferral")
  referredByReferral Referral?         @relation("UserReferredBy", fields: [referredByReferralId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

type SceneSettings {
  tense       String? @default("present")
  pov         String? @default("first")
  perspective String? @db.ObjectId
}

type StorySettings {
  sceneDefaults SceneSettings
  updatedAt     DateTime
  metadata      Json?
}

model Story {
  id                 String         @id @default(auto()) @map("_id") @db.ObjectId
  userId             String         @db.ObjectId
  title              String         @default("Untitled")
  mode               String         @default("novel")
  penName            String?
  onboardingComplete Boolean        @default(false)
  wordCount          Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  lastEditedAt       DateTime?
  user               User           @relation("UserStories", fields: [userId], references: [id], onDelete: Cascade)
  settings           StorySettings?
  scenes             Scene[]        @relation("StoryScenes")
  mentions           Mention[]
  mentioned          Mentioned[]    @relation("StoryMentionFrequency")
  notes              Note[]
  comments           Comment[]
  attributes         Attribute[]    @relation("StoryAttributes")
  highlights         Highlight[]    @relation("StoryHighlights")
  platformPosts      PlatformPost[] @relation("StoryPlatformPosts")
}

model Scene {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  storyId         String        @db.ObjectId
  shortId         String        @unique
  activeVersionId String?
  label           String?       @default("Untitled Scene")
  order           Float
  summary         String?
  settings        SceneSettings
  visible         Boolean       @default(true)
  color           String?       @default("amber")
  threadCount     Int           @default(0)
  mentionCount    Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime?     @updatedAt
  lastAnalyzedAt  DateTime?
  groupId         String?       @db.ObjectId

  versions  SceneVersion[] @relation("SceneVersion")
  mentioned Mentioned[]
  notes     Note[]

  group SceneGroup? @relation("SceneGroup", fields: [groupId], references: [id], onDelete: Cascade)
  story Story       @relation("StoryScenes", fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId, order])
  @@index([storyId, visible, order])
}

model SceneVersion {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  sceneId   String   @db.ObjectId
  shortId   String
  data      Json?
  label     String?  @default("Draft")
  plainText String?
  wordCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scene Scene @relation("SceneVersion", fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([sceneId, createdAt])
}

model SceneGroup {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  storyId   String   @db.ObjectId
  shortId   String
  label     String?  @default("Untitled Group")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scenes Scene[] @relation("SceneGroup")

  @@index([storyId, shortId])
  @@index([storyId, label])
}

enum MentionType {
  person
  place
  thing
  group
}

model Mention {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  storyId      String      @db.ObjectId
  userId       String      @db.ObjectId
  name         String
  mentionType  MentionType
  status       String      @default("pending")
  color        String?
  aliases      Json[]      @default([])
  mentionCount Int         @default(0)
  metadata     Json?
  threadIds    String[]    @db.ObjectId
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  story      Story            @relation(fields: [storyId], references: [id], onDelete: Cascade)
  mentioned  Mentioned[]      @relation("MentionFrequency")
  context    MentionContext[]
  attributes Attribute[]      @relation("MentionAttributes")

  @@index([storyId, mentionType, status])
  @@index([storyId, mentionCount])
}

model Mentioned {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  storyId        String   @db.ObjectId
  sceneVersionId String?  @db.ObjectId
  mentionId      String   @db.ObjectId
  targetWord     String
  context        String?
  source         String   @default("explicit")
  confidence     Float    @default(1.0)
  createdAt      DateTime @default(now())

  story   Story   @relation("StoryMentionFrequency", fields: [storyId], references: [id], onDelete: Cascade)
  mention Mention @relation("MentionFrequency", fields: [mentionId], references: [id], onDelete: Cascade)
  sceneId String? @db.ObjectId
  scene   Scene?  @relation(fields: [sceneId], references: [id])

  @@index([storyId, mentionId])
  @@index([sceneVersionId])
}

model MentionContext {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  mentionId String   @db.ObjectId
  query     String?
  category  String?
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mention Mention @relation(fields: [mentionId], references: [id], onDelete: Cascade)

  @@index([mentionId])
}

model Note {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  storyId   String   @db.ObjectId
  sceneId   String?  @db.ObjectId
  body      String
  color     String   @default("amber")
  status    String?  @default("pending")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  story Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  scene Scene? @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([color, sceneId])
}

model Comment {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  storyId          String    @db.ObjectId
  sceneId          String?   @db.ObjectId
  sceneVersionId   String?   @db.ObjectId
  noteId           String?   @db.ObjectId
  userId           String    @db.ObjectId
  parentId         String?   @db.ObjectId
  type             String?   @default("storyboard")
  body             String
  anchorOffset     Int?
  anchorLength     Int?
  anchorText       String?
  isStale          Boolean   @default(false)
  resolvedAt       DateTime?
  resolvedByUserId String?   @db.ObjectId
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  story   Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies Comment[] @relation("CommentReplies")

  @@index([storyId, createdAt])
  @@index([storyId, sceneId, createdAt])
  @@index([parentId, createdAt])
  @@index([storyId, resolvedAt, createdAt])
}

model Referral {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  userId             String   @unique @db.ObjectId
  trialLengthDays    Int      @default(30)
  referralCode       String   @unique
  referralsCount     Int      @default(0)
  paidReferralsCount Int      @default(0)
  createdAt          DateTime @default(now())

  user          User   @relation("UserOwnReferral", fields: [userId], references: [id], onDelete: Cascade)
  referredUsers User[] @relation("UserReferredBy")
}

model Waitlist {
  id                         String    @id @default(auto()) @map("_id") @db.ObjectId
  email                      String    @unique
  approved                   Boolean   @default(false)
  trialLengthDays            Int       @default(7)
  referralCode               String    @unique
  referredById               String?   @db.ObjectId
  referralsCount             Int       @default(0)
  paidReferralsCount         Int       @default(0)
  confirmedAt                DateTime?
  confirmationTokenHash      String?
  confirmationTokenExpiresAt DateTime?
  referralCreditedAt         DateTime?
  createdAt                  DateTime  @default(now())

  @@index([confirmedAt, referralsCount, createdAt])
  @@index([referredById])
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  unpaid
}

enum PaidSubscriptionTier {
  starter
  writer
  pro
}

model UserSubscription {
  id                 String               @id @default(auto()) @map("_id") @db.ObjectId
  user               User                 @relation("UserSubscriber", fields: [userId], references: [id], onDelete: Cascade)
  userId             String               @unique @db.ObjectId
  stripeCustomerId   String?
  subscriptionStatus SubscriptionStatus   @default(trialing)
  tier               PaidSubscriptionTier
  metadata           Json? // for extensibility, e.g. recording referral source, promotion code, etc.
  expiresAt          DateTime
  trialEndsAt        DateTime?            @default(now())
  createdAt          DateTime             @default(now())
}

// Generic event log — metadata only, no prompt/response content.
// userId and storyId are stored as plain strings (no Prisma relation) so
// this table remains decoupled and events survive entity deletion.
model AppEvent {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Taxonomy
  eventType  String // e.g. "ai.call.completed", "simulation.run.cache_hit"
  eventGroup String // e.g. "ai", "simulation", "block_analysis"
  source     String // service/worker name that emitted the event

  // Outcome
  status     String // "success" | "error" | "skipped"
  occurredAt DateTime @default(now())
  durationMs Int?

  // Ownership (plain ObjectId strings — no cascade relation)
  userId  String? @db.ObjectId
  storyId String? @db.ObjectId

  // Tracing
  requestId String? // propagated from HTTP request-id header when available

  // AI-specific usage (counts only — no tokens from prompt/response bodies)
  provider         String? // "anthropic" | "openai"
  model            String? // e.g. "gpt-4o-mini", "claude-sonnet-4-20250514"
  inputUnits       Int? // input token count returned by provider SDK
  outputUnits      Int? // output token count returned by provider SDK
  estimatedCostUsd Float? // estimated USD cost based on published per-token pricing

  // Event-type-specific payload (sanitized, no user content)
  metadata Json

  @@index([eventGroup, occurredAt])
  @@index([eventType, occurredAt])
  @@index([userId, occurredAt])
  @@index([storyId, occurredAt])
}

model Attribute {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  storyId        String   @db.ObjectId
  label          String
  type           String   @default("text")
  value          String
  keyAttributeId String?  @db.ObjectId
  mentionId      String   @db.ObjectId
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  keyAttribute KeyAttribute? @relation("KeyAttributes", fields: [keyAttributeId], references: [id])
  mentions     Mention       @relation("MentionAttributes", references: [id], fields: [mentionId])
  story        Story         @relation("StoryAttributes", fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId, createdAt])
  @@index([mentionId])
  @@index([storyId, mentionId])
}

model KeyAttribute {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  storyId      String      @db.ObjectId
  label        String
  context      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  attributeIds String[]    @db.ObjectId
  attributes   Attribute[] @relation("KeyAttributes")

  @@index([storyId, attributeIds])
}

model Highlight {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  storyId         String   @db.ObjectId
  label           String   @default("Untitled Highlight")
  shortId         String   @default("amber")
  backgroundColor String   @default("#FFC107")
  color           String   @default("#000000")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  story Story @relation("StoryHighlights", fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId, createdAt])
  @@index([storyId, shortId])
  @@index([storyId, label])
}

enum EntityType {
  PLATFORM
  NOTE
  COMMENT
}

enum PlatformInputType {
  input
  note
  comment
  link
}

enum AppliedEntityType {
  mention
  scene
  note
}

model PlatformPost {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  userId       String            @db.ObjectId
  storyId      String            @db.ObjectId
  type         EntityType        @default(PLATFORM)
  platformType PlatformInputType @default(input)
  body         String?
  content      Json?
  color        String?
  user         User              @relation("UserPosts", fields: [userId], references: [id], onDelete: Cascade)
  story        Story             @relation("StoryPlatformPosts", fields: [storyId], references: [id], onDelete: Cascade)
  items        PlatformItem[]    @relation("PlatformPosts")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([userId, createdAt])
  @@index([storyId, createdAt])
}

enum PlatformStatus {
  PENDING
  APPROVED
  REJECTED
}

type PlatformData {
  label String
  type  String @default("text")
  value String
}

model PlatformItem {
  id                String             @id @default(auto()) @map("_id") @db.ObjectId
  storyId           String             @db.ObjectId
  action            String?
  data              PlatformData[]
  body              String?
  status            PlatformStatus     @default(PENDING)
  postId            String?            @db.ObjectId
  post              PlatformPost?      @relation("PlatformPosts", fields: [postId], references: [id], onDelete: Cascade)
  appliedEntityId   String?            @db.ObjectId
  appliedEntityType AppliedEntityType?
  rejectionReason   String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  approvedAt        DateTime?
  rejectedAt        DateTime?

  @@index([storyId, status])
  @@index([postId])
}

enum StoryInputSource {
  editor_scene
  platform
  line_feedback
  note
  comment
}

enum CanonStatus {
  canon
  intent
}

enum ThreadLayer {
  character_arc
  relationship
  plot_line
  subplot
  beat
  world_rule
  tone
}

enum ThreadStatus {
  open
  advanced
  resolved
  contradicted
}

enum IntelligenceRunStatus {
  queued
  running
  completed
  skipped
  failed
}

model StoryInput {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  storyId        String           @db.ObjectId
  userId         String           @db.ObjectId
  source         StoryInputSource
  canonStatus    CanonStatus
  plainText      String?
  contentHash    String
  sceneId        String?          @db.ObjectId
  sceneVersionId String?          @db.ObjectId
  mentionId      String?          @db.ObjectId
  noteId         String?          @db.ObjectId
  metadata       Json?
  createdAt      DateTime         @default(now())

  runs IntelligenceRun[]

  @@index([storyId, createdAt])
  @@index([storyId, source])
  @@index([sceneId, contentHash])
}

model Thread {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  storyId          String       @db.ObjectId
  layer            ThreadLayer
  status           ThreadStatus @default(open)
  canonStatus      CanonStatus
  confidence       Float        @default(0.8)
  summary          String
  body             Json
  pecFlags         String[]     @default([])
  sourceInputId    String?      @db.ObjectId
  mentionIds       String[]     @db.ObjectId
  sceneIds         String[]     @db.ObjectId
  relatedThreadIds String[]     @db.ObjectId
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([storyId, layer, status])
  @@index([storyId, canonStatus])
}

model IntelligenceRun {
  id             String                @id @default(auto()) @map("_id") @db.ObjectId
  storyId        String                @db.ObjectId
  inputId        String                @db.ObjectId
  jobType        String
  status         IntelligenceRunStatus
  sceneId        String?               @db.ObjectId
  threadsCreated Int                   @default(0)
  threadsUpdated Int                   @default(0)
  diagnostic     String?
  durationMs     Int?
  createdAt      DateTime              @default(now())
  completedAt    DateTime?

  input StoryInput @relation(fields: [inputId], references: [id], onDelete: Cascade)

  @@index([storyId, createdAt])
  @@index([inputId])
}
